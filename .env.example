# Firebase (ใช้ชุดใดชุดหนึ่ง: NEXT_PUBLIC_* สำหรับ Next.js หรือ VITE_* สำหรับ Vite/legacy)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
# หรือใช้ VITE_FIREBASE_* (รองรับทั้งสองแบบ)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# Google Places API (สำหรับค้นหาสถานที่ใกล้เคียงอัตโนมัติ)
VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Longdo Map (แผนที่ PropertiesMap และ MapPicker) - ดึง key ได้ที่ https://map.longdo.com/api
VITE_LONGDO_MAP_KEY=your_longdo_map_key

# Firebase Admin (สำหรับ SSR: หน้าแรก, รายการบ้าน, รายละเอียดทรัพย์) — ใช้อย่างใดอย่างหนึ่ง
# วิธีที่ 1: path ไปที่ไฟล์ Service Account key (โหลดจาก Firebase Console > Project settings > Service accounts)
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
# วิธีที่ 2: JSON ของ Service Account แบบ string (เหมาะกับ Vercel/hosting ที่ไม่มีไฟล์)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project",...}
# ถ้าไม่ตั้งค่า ระบบจะใช้ Application Default Credentials (ต้องมี projectId จาก NEXT_PUBLIC_FIREBASE_PROJECT_ID)
